# Production environment template
# Copy values into your AWS service configuration (ECS task definitions, etc.)
# Do not commit real secrets.
#
# Production URLs must use HTTPS. Configure ACM and ALB listeners before deploying.

# Application environment — must be "production" for deployed services
APP_ENV=production

# PostgreSQL connection string (RDS or other managed PostgreSQL)
# Format: postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql+psycopg://db_user:replace-me@your-rds-endpoint.region.rds.amazonaws.com:5432/finance_app

# JWT signing key — use a strong random value, at least 32 characters
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars

# Comma-separated browser origins allowed to call the API
# Must use HTTPS in production (exact frontend domain, no trailing slash)
CORS_ORIGINS=https://your-frontend.example.com

# Public backend URL used by the browser
# Required at frontend Docker image build time — baked into the Next.js bundle
# Must use HTTPS in production
NEXT_PUBLIC_API_URL=https://your-api.example.com

# Cookie defaults for future httpOnly authentication
# Secure must be true when serving over HTTPS
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_HTTPONLY=true

# Optional — JWT access token lifetime in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
