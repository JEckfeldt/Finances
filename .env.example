# Application environment: development | production
# development — auto-creates tables and runs lightweight startup migrations
# production — skips automatic schema changes; provision schema separately
APP_ENV=development

# PostgreSQL (used by Docker Compose)
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_pass
POSTGRES_DB=finance_app

# Backend
DATABASE_URL=postgresql+psycopg://finance_user:finance_pass@localhost:5432/finance_app
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated allowed frontend origins (local development uses HTTP)
CORS_ORIGINS=http://localhost:3000

# Cookie settings for httpOnly JWT authentication
# Development keeps Secure=false so local HTTP testing works.
# Leave COOKIE_DOMAIN empty locally (host-only cookies for localhost:8000).
ACCESS_TOKEN_COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_HTTPONLY=true
COOKIE_DOMAIN=

# AI (backend only — GEMINI_API_KEY must never be exposed to the frontend)
# To enable AI Insights locally:
#   1. Set AI_ENABLED=true
#   2. Set GEMINI_API_KEY to your Google AI Studio / Gemini API key
#   3. Restart backend: docker compose up -d backend
# Docker Compose reads this file from the repo root and passes these vars to the backend container.
AI_ENABLED=false
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# Backend tests (optional — defaults to finance_app_test on localhost)
# TEST_DATABASE_URL=postgresql+psycopg://finance_user:finance_pass@localhost:5432/finance_app_test

# Frontend (browser-accessible backend URL; baked into the Next.js build in Docker)
# Local development uses HTTP. Production builds must use HTTPS URLs.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production template: see .env.production.example
